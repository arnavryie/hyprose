#!/usr/bin/env bash
# hyprose-live-setup — initializes end-4 dots-hyprland in the live session
# Runs as the `hyprose` user via .bash_profile on tty1

set -euo pipefail

# ── Colors ─────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; PINK='\033[1;35m'; RESET='\033[0m'

log()  { echo -e "${CYAN}[hyprose]${RESET} $*"; }
ok()   { echo -e "${GREEN}[  OK  ]${RESET} $*"; }
warn() { echo -e "${YELLOW}[ WARN ]${RESET} $*"; }
err()  { echo -e "${RED}[ FAIL ]${RESET} $*"; }

DOTS_REPO="https://github.com/end-4/dots-hyprland.git"
DOTS_DIR="$HOME/.local/share/dots-hyprland"
LOCK_FILE="$HOME/.hyprose-live-done"

# ── Skip if already set up ─────────────────────────────────────────────────
if [[ -f "$LOCK_FILE" ]]; then
    log "Live setup already done, launching Hyprland..."
    exec Hyprland
fi

clear
echo -e "${PINK}"
cat << 'EOF'
  _   _                                
 | | | |_   _ _ __  _ __ ___  ___  ___ 
 | |_| | | | | '_ \| '__/ _ \/ __|/ _ \
 |  _  | |_| | |_) | | | (_) \__ \  __/
 |_| |_|\__, | .__/|_|  \___/|___/\___|
        |___/|_|                        
EOF
echo -e "${RESET}"
log "Welcome to Hyprose Linux — Setting up your desktop..."
echo ""

# ── Wait for network ───────────────────────────────────────────────────────
log "Waiting for network..."
TRIES=0
until ping -c 1 github.com &>/dev/null 2>&1; do
    sleep 2
    TRIES=$((TRIES + 1))
    if [[ $TRIES -gt 15 ]]; then
        warn "No network detected. Will use fallback config."
        break
    fi
done

# ── Clone dots-hyprland ────────────────────────────────────────────────────
if [[ ! -d "$DOTS_DIR" ]]; then
    log "Cloning end-4/dots-hyprland..."
    git clone --depth=1 "$DOTS_REPO" "$DOTS_DIR" || {
        warn "Clone failed. Using bundled fallback config."
        mkdir -p "$DOTS_DIR"
    }
else
    ok "Dots already cloned."
fi

# ── Run install script non-interactively ──────────────────────────────────
if [[ -f "$DOTS_DIR/install.sh" ]]; then
    log "Running dots install script..."
    cd "$DOTS_DIR"
    # Run with --noconfirm equivalent — dots-hyprland respects HYPROSE_LIVE=1
    export HYPROSE_LIVE=1
    export IFS_INSTALL_UNATTENDED=1
    bash install.sh --noconfirm 2>/dev/null || warn "Install script had non-fatal errors."
    cd ~
    ok "Dots installed."
else
    warn "install.sh not found in dots repo — manually copying configs..."
    mkdir -p "$HOME/.config"
    cp -r "$DOTS_DIR"/.config/* "$HOME/.config/" 2>/dev/null || true
fi

# ── Copy wallpapers ────────────────────────────────────────────────────────
WALLPAPER_SRC="/usr/local/share/backgrounds/hyprose"
WALLPAPER_DST="$HOME/Pictures/Wallpapers"
if [[ -d "$WALLPAPER_SRC" ]]; then
    mkdir -p "$WALLPAPER_DST"
    cp -r "$WALLPAPER_SRC"/. "$WALLPAPER_DST/" 2>/dev/null || true
    ok "Wallpapers copied."
fi

# ── Set default wallpaper ──────────────────────────────────────────────────
DEFAULT_WALL=$(find "$WALLPAPER_DST" -name "*.jpg" -o -name "*.png" 2>/dev/null | head -1)
if [[ -n "$DEFAULT_WALL" ]]; then
    mkdir -p "$HOME/.config/hypr"
    echo "exec-once = swww-daemon && swww img \"$DEFAULT_WALL\" --transition-type grow" \
        > "$HOME/.config/hypr/hyprose-wallpaper.conf"
fi

# ── Mark setup done ────────────────────────────────────────────────────────
touch "$LOCK_FILE"
ok "Live setup complete!"
sleep 1

# ── Launch Hyprland ────────────────────────────────────────────────────────
log "Launching Hyprland..."
exec Hyprland
