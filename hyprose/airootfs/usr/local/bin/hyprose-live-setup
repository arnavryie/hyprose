#!/usr/bin/env bash
# hyprose-live-setup — launches the Hyprose live desktop
# Configs are pre-baked into /etc/skel at ISO build time. No network needed.

CYAN='\033[0;36m'; PINK='\033[1;35m'; RESET='\033[0m'

clear
echo -e "${PINK}"
cat << 'EOF'
  _   _
 | | | |_   _ _ __  _ __ ___  ___  ___
 | |_| | | | | '_ \| '__/ _ \/ __|/ _ \
 |  _  | |_| | |_) | | | (_) \__ \  __/
 |_| |_|\__, | .__/|_|  \___/|___/\___|
        |___/|_|
EOF
echo -e "${RESET}"
echo -e "${CYAN}[hyprose]${RESET} Starting your desktop..."

# VM-friendly cursor handling (harmless on real hardware)
export WLR_NO_HARDWARE_CURSORS=1
export AQ_NO_HARDWARE_CURSORS=1

# Software rendering fallback for VMs without 3D acceleration
if ! lspci 2>/dev/null | grep -qiE "nvidia|amd|radeon|intel.*graphics"; then
    export WLR_RENDERER_ALLOW_SOFTWARE=1
fi

exec Hyprland
