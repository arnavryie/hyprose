#!/usr/bin/env bash
# hyprose-installer вҖ” Hyprose Linux TUI installer
# Supports UEFI + BIOS, NVIDIA/AMD/Intel GPU detection

set -euo pipefail

# в”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; PINK='\033[1;35m'; BOLD='\033[1m'; RESET='\033[0m'

log()     { echo -e "${CYAN}[hyprose]${RESET} $*"; }
ok()      { echo -e "${GREEN}[  OK  ]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[ WARN ]${RESET} $*"; }
err()     { echo -e "${RED}[ FAIL ]${RESET} $*"; exit 1; }
section() { echo -e "\n${PINK}${BOLD}в”Ғв”Ғв”Ғ $* в”Ғв”Ғв”Ғ${RESET}\n"; }

MOUNT="/mnt"
LOG_FILE="/tmp/hyprose-install.log"
DOTS_REPO="https://github.com/end-4/dots-hyprland.git"

# в”Җв”Җ Root check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[[ $EUID -ne 0 ]] && err "Run as root: sudo hyprose-installer"

# в”Җв”Җ UEFI detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
IS_UEFI=false
[[ -d /sys/firmware/efi ]] && IS_UEFI=true
log "Boot mode: $( $IS_UEFI && echo 'UEFI' || echo 'BIOS/Legacy' )"

# в”Җв”Җ GPU detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
detect_gpu() {
    GPU_PKGS=()
    if lspci | grep -qi "nvidia"; then
        GPU_PKGS=(nvidia nvidia-utils nvidia-settings lib32-nvidia-utils)
        GPU_TYPE="NVIDIA"
    elif lspci | grep -qi "amd\|radeon"; then
        GPU_PKGS=(mesa vulkan-radeon libva-mesa-driver mesa-vdpau lib32-mesa lib32-vulkan-radeon)
        GPU_TYPE="AMD"
    else
        GPU_PKGS=(mesa vulkan-intel intel-media-driver lib32-mesa lib32-vulkan-intel)
        GPU_TYPE="Intel"
    fi
    log "Detected GPU: $GPU_TYPE вҶ’ installing: ${GPU_PKGS[*]}"
}

# в”Җв”Җ Welcome screen в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear
echo -e "${PINK}${BOLD}"
cat << 'BANNER'
  в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ
  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  
  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘  в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  
  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в•ҡв•җв•қ  в•ҡв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ
BANNER
echo -e "${RESET}"
echo -e "  ${CYAN}Hyprland вҖ” pre-configured, out of the box${RESET}"
echo -e "  ${YELLOW}This will ERASE the selected disk. Make backups first.${RESET}"
echo ""
read -rp "  Press ENTER to continue or Ctrl+C to cancel... "

# в”Җв”Җ Disk selection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Disk Selection"
log "Available disks:"
echo ""
lsblk -d -o NAME,SIZE,MODEL,TYPE | grep -v "loop\|rom\|sr" | grep "disk"
echo ""
read -rp "Enter disk name (e.g. sda, nvme0n1): " DISK_NAME
DISK="/dev/$DISK_NAME"
[[ ! -b "$DISK" ]] && err "Disk $DISK not found."

DISK_SIZE=$(lsblk -d -o SIZE "$DISK" | tail -1 | tr -d ' ')
echo ""
warn "вҡ   WARNING: ALL DATA ON $DISK ($DISK_SIZE) WILL BE ERASED!"
read -rp "Type 'yes' to confirm: " CONFIRM
[[ "$CONFIRM" != "yes" ]] && { log "Cancelled."; exit 0; }

# в”Җв”Җ Partition в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Partitioning"
log "Wiping $DISK..."
wipefs -af "$DISK" >> "$LOG_FILE" 2>&1
sgdisk --zap-all "$DISK" >> "$LOG_FILE" 2>&1

if $IS_UEFI; then
    log "Creating GPT partition table (UEFI)..."
    sgdisk -n 1:0:+512M  -t 1:ef00 -c 1:"EFI"  "$DISK" >> "$LOG_FILE" 2>&1
    sgdisk -n 2:0:+4G    -t 2:8200 -c 2:"swap" "$DISK" >> "$LOG_FILE" 2>&1
    sgdisk -n 3:0:0      -t 3:8300 -c 3:"root" "$DISK" >> "$LOG_FILE" 2>&1
    # Partition naming (nvme vs sata)
    if [[ "$DISK" == *"nvme"* ]]; then
        PART_EFI="${DISK}p1"
        PART_SWAP="${DISK}p2"
        PART_ROOT="${DISK}p3"
    else
        PART_EFI="${DISK}1"
        PART_SWAP="${DISK}2"
        PART_ROOT="${DISK}3"
    fi
else
    log "Creating MBR partition table (BIOS)..."
    parted -s "$DISK" mklabel msdos >> "$LOG_FILE" 2>&1
    parted -s "$DISK" mkpart primary linux-swap 1MiB 4GiB >> "$LOG_FILE" 2>&1
    parted -s "$DISK" mkpart primary ext4 4GiB 100% >> "$LOG_FILE" 2>&1
    parted -s "$DISK" set 2 boot on >> "$LOG_FILE" 2>&1
    if [[ "$DISK" == *"nvme"* ]]; then
        PART_SWAP="${DISK}p1"
        PART_ROOT="${DISK}p2"
    else
        PART_SWAP="${DISK}1"
        PART_ROOT="${DISK}2"
    fi
fi
ok "Partitions created."

# в”Җв”Җ Format в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Formatting"
log "Formatting partitions..."
$IS_UEFI && mkfs.fat -F32 -n "HYPROSEEFI" "$PART_EFI" >> "$LOG_FILE" 2>&1
mkswap -L "hyprose-swap" "$PART_SWAP" >> "$LOG_FILE" 2>&1
mkfs.ext4 -L "hyprose-root" "$PART_ROOT" >> "$LOG_FILE" 2>&1
ok "Formatted."

# в”Җв”Җ Mount в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Mounting"
mount "$PART_ROOT" "$MOUNT"
swapon "$PART_SWAP"
if $IS_UEFI; then
    mkdir -p "$MOUNT/boot/efi"
    mount "$PART_EFI" "$MOUNT/boot/efi"
fi
ok "Mounted at $MOUNT."

# в”Җв”Җ User setup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "User Configuration"
read -rp "Hostname [hyprose]: " HOSTNAME
HOSTNAME="${HOSTNAME:-hyprose}"
read -rp "Username: " USERNAME
while [[ -z "$USERNAME" ]]; do
    warn "Username cannot be empty."
    read -rp "Username: " USERNAME
done
read -rsp "Password for $USERNAME: " USER_PASS; echo ""
read -rsp "Root password: " ROOT_PASS; echo ""
read -rp "Timezone [Asia/Kolkata]: " TIMEZONE
TIMEZONE="${TIMEZONE:-Asia/Kolkata}"

# в”Җв”Җ Detect GPU в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "GPU Detection"
detect_gpu

# в”Җв”Җ Pacstrap в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Installing Base System"
log "Running pacstrap (this takes ~10-30 minutes)..."
EXTRA_PKGS=(
    base base-devel linux linux-firmware linux-headers
    systemd networkmanager sudo vim nano git curl wget
    hyprland hyprlock hypridle xdg-desktop-portal-hyprland
    xdg-desktop-portal-gtk pipewire pipewire-alsa pipewire-pulse
    wireplumber swww waybar dunst libnotify rofi-wayland
    kitty thunar gvfs fastfetch btop bat eza fzf
    noto-fonts noto-fonts-emoji ttf-jetbrains-mono-nerd
    grub efibootmgr dosfstools
    "${GPU_PKGS[@]}"
)
pacstrap -K "$MOUNT" "${EXTRA_PKGS[@]}" >> "$LOG_FILE" 2>&1
ok "Base system installed."

# в”Җв”Җ fstab в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Generating fstab"
genfstab -U "$MOUNT" >> "$MOUNT/etc/fstab"
ok "fstab written."

# в”Җв”Җ chroot setup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Configuring System"
log "Entering chroot..."

arch-chroot "$MOUNT" /bin/bash << CHROOT
set -euo pipefail

# Timezone
ln -sf /usr/share/zoneinfo/${TIMEZONE} /etc/localtime
hwclock --systohc

# Locale
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf

# Hostname
echo "${HOSTNAME}" > /etc/hostname
cat > /etc/hosts << HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${HOSTNAME}.localdomain ${HOSTNAME}
HOSTS

# Passwords
echo "root:${ROOT_PASS}" | chpasswd
useradd -m -G wheel,audio,video,storage,optical -s /bin/bash "${USERNAME}"
echo "${USERNAME}:${USER_PASS}" | chpasswd

# Sudo
echo "%wheel ALL=(ALL:ALL) ALL" > /etc/sudoers.d/wheel

# mkinitcpio
mkinitcpio -P

# Enable services
systemctl enable NetworkManager
systemctl enable bluetooth 2>/dev/null || true

# Copy Hyprose first-boot script
cp /usr/local/bin/hyprose-first-boot /home/${USERNAME}/.hyprose-first-boot 2>/dev/null || true
chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.hyprose-first-boot 2>/dev/null || true
chmod +x /home/${USERNAME}/.hyprose-first-boot 2>/dev/null || true

# Add first-boot to user .bash_profile
cat >> /home/${USERNAME}/.bash_profile << PROFILE

# Hyprose first-boot
if [[ ! -f "\$HOME/.hyprose-firstboot-done" ]]; then
    bash "\$HOME/.hyprose-first-boot"
fi

# Auto-start Hyprland on tty1
if [[ \$(tty) == /dev/tty1 ]]; then
    exec Hyprland
fi
PROFILE
chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.bash_profile

CHROOT

ok "Chroot setup done."

# в”Җв”Җ Bootloader в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Bootloader"
if $IS_UEFI; then
    log "Installing systemd-boot (UEFI)..."
    arch-chroot "$MOUNT" bootctl install >> "$LOG_FILE" 2>&1
    ROOT_UUID=$(blkid -s UUID -o value "$PART_ROOT")
    mkdir -p "$MOUNT/boot/efi/loader/entries"
    cat > "$MOUNT/boot/efi/loader/loader.conf" << EOF
default hyprose.conf
timeout 5
console-mode auto
editor no
EOF
    cat > "$MOUNT/boot/efi/loader/entries/hyprose.conf" << EOF
title   Hyprose Linux
linux   /vmlinuz-linux
initrd  /initramfs-linux.img
options root=UUID=$ROOT_UUID rw quiet splash loglevel=3
EOF
else
    log "Installing GRUB (BIOS)..."
    arch-chroot "$MOUNT" grub-install --target=i386-pc "$DISK" >> "$LOG_FILE" 2>&1
    arch-chroot "$MOUNT" grub-mkconfig -o /boot/grub/grub.cfg >> "$LOG_FILE" 2>&1
fi
ok "Bootloader installed."

# в”Җв”Җ Cleanup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
section "Finishing Up"
log "Unmounting..."
$IS_UEFI && umount "$MOUNT/boot/efi" 2>/dev/null || true
umount -R "$MOUNT" 2>/dev/null || true
swapoff "$PART_SWAP" 2>/dev/null || true
ok "Unmounted."

echo ""
echo -e "${PINK}${BOLD}  вң“ Hyprose installed successfully!${RESET}"
echo -e "  Full log: $LOG_FILE"
echo ""
read -rp "  Reboot now? [Y/n]: " DO_REBOOT
[[ "${DO_REBOOT:-Y}" =~ ^[Yy]$ ]] && reboot
